# ============================================
# CLI Agent Orchestrator — Environment Variables
# ============================================
#
# Copy this file to .env and fill in the values.
# The orchestrator will fail to start if required vars are missing.
#
# NEVER commit .env to git — it contains secrets.

# --------------------------------------------
# REQUIRED: JWT Secret
# --------------------------------------------
# Used to sign and verify agent authentication tokens.
# Must be at least 32 characters long.
# Generate one with: openssl rand -base64 48
# Or use: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
ORCHESTRATOR_JWT_SECRET=

# --------------------------------------------
# OPTIONAL: Admin API Key
# --------------------------------------------
# Used to authenticate admin requests (create agents, list providers, etc.)
# If not set, admin endpoints are inaccessible.
# Generate one with: openssl rand -hex 32
ORCHESTRATOR_ADMIN_API_KEY=

# --------------------------------------------
# OPTIONAL: Server Port
# --------------------------------------------
# Default: 3000
# PORT=3000

# --------------------------------------------
# OPTIONAL: JWT Token Expiration
# --------------------------------------------
# How long agent tokens remain valid.
# Default: 1h
# Format: number + unit (s, m, h, d)
# ORCHESTRATOR_JWT_EXPIRES_IN=1h

# ============================================
# Provider API Keys (fill only the ones you use)
# ============================================

# --------------------------------------------
# Anthropic — Claude Code
# --------------------------------------------
# Get your key at: https://console.anthropic.com/settings/keys
# Required for the 'claude' adapter.
ANTHROPIC_API_KEY=

# --------------------------------------------
# OpenAI — Codex CLI
# --------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
# Required for the 'codex' adapter.
OPENAI_API_KEY=

# --------------------------------------------
# Moonshot — Kimi Code
# --------------------------------------------
# Get your key at: https://platform.moonshot.cn/
# Required for the 'kimi' adapter.
KIMI_API_KEY=
